{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devdeck.local/schemas/command.schema.json",
  "title": "DevDeck Command",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "description",
    "category",
    "command",
    "icon"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "vercel",
        "github",
        "docker",
        "database",
        "ssh",
        "npm",
        "workflow",
        "custom"
      ]
    },
    "command": {
      "type": "string"
    },
    "shortcut": {
      "type": "string"
    },
    "icon": {
      "type": "string",
      "minLength": 1
    },
    "dangerous": {
      "type": "boolean"
    },
    "requiresConfirmation": {
      "type": "boolean"
    },
    "params": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "type",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "string",
              "select",
              "boolean"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "default": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "wired",
        "stub"
      ]
    }
  }
}
