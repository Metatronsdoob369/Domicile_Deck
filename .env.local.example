# Domicile Deck — local environment variables
# Copy this file to .env.local and fill in your values.

# App
NEXT_PUBLIC_APP_NAME=Domicile Deck

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=replace_with_a_strong_random_secret
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth provider (optional — remove if unused)
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# Local credential users (development only — use hashed passwords in production)
ADMIN_PASSWORD=change-me-admin
OPERATOR_PASSWORD=change-me-operator

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Terminal server (optional) ──────────────────────────────────────────────
# Only needed when running server/terminal-server.js
TERMINAL_PORT=3211
TERMINAL_ALLOWED_ROOTS=/your/project/root,/another/allowed/path
TERMINAL_AUTH_TOKEN=replace_with_a_strong_random_secret

# ─── Third-party integrations (optional) ─────────────────────────────────────
OPENAI_API_KEY=sk-your-key
VERCEL_ANALYTICS_ID=
